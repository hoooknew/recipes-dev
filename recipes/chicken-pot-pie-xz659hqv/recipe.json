  "step_sections": [
    {
      "steps": [
        "Mix all the dough ingredients together; dough needs to rest in the fridge for 4 hours or overnight.",
        "Slice vegetables into similar sizes (large dice).",
        "Melt butter and chicken fat in a large pan or Dutch oven. Add onions, carrots, celery, leeks, garlic, thyme, pepper, and salt. Sweat the vegetables over low-medium heat for 5-6 minutes.",
        "Add AP flour and chicken bouillon powder; stir for about 2 minutes.",
        "Add chicken stock and heavy cream, stirring to combine. Bring to a simmer.",
        "Fold in shredded chicken, parmesan cheese, parsley, and peas.",
        "Spread filling on a sheet tray and cool in the fridge.",
        "Roll out dough to 1/4 inch and line the pie tin(s).",
        "Fill with the cooled filling. Top with the second crust and create an air hole.",
        "Crimp the edges, brush with egg wash, and sprinkle with salt.",
        "Bake at 400°F for about 40 to 50 minutes on the middle rack.",
        "Allow to cool before serving to ensure the filling sets."
      ]
    }
  ]
