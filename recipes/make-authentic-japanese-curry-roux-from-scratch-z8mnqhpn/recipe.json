  "step_sections": [
    {
      "name": "Method",
      "steps": [
        "Make a brown roux: equal-weight oil/butter and flour; whisk until deep blonde/brown.",
        "Bloom spices in the roux 60–90s (don’t burn).",
        "Whisk in cold water gradually to smooth (prevents lumps).",
        "Off heat: add soy, Worcestershire, honey/sugar; tuck in bay leaves to infuse.",
        "Cool into a “brick” (or freeze). Start with 100g roux per 800ml liquid, then adjust salt/heat/thickness."
      ]
    }
  ],
  "notes": "(Use equal parts in weight, not unit, to factor in difference in density.)"
