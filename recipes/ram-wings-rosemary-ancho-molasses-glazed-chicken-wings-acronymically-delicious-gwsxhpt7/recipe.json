  ],
  "step_sections": [
    {
      "steps": [
        "Bake at 400 F. for 45 minutes or until the bones come out clean"
      ]
    },
    {
      "name": "For the finishing glaze (use a clean bowl)",
      "steps": [
        "2 teaspoons molasses",
        "1 tablespoon honey",
        "1 teaspoon ancho chili powder",
        "pinch of cayenne",
        "pinch of salt",
        "1 fresh juiced lime"
      ]
    }
  ],
  "notes": "* If you can't find ancho chili powder, you can use 4 parts paprika mixed with 1 part ground chipotle."
